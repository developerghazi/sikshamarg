# Copy to .env.local in the project root (same folder as package.json), not under src/.
#
# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address that will receive contact form submissions
CONTACT_FORM_TO_EMAIL=info@sikshaMarg.com

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
